# =============================================================================
# Cue — Environment Variables
# Copy this file to .env.local for local development.
# Add each variable to Vercel via: vercel env add <KEY>
# =============================================================================


# -----------------------------------------------------------------------------
# EXISTING
# -----------------------------------------------------------------------------

# Your Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated list of allowed CORS origins for /api/analyze
ALLOWED_ORIGIN=https://your-app.vercel.app,http://localhost:3000


# -----------------------------------------------------------------------------
# DATABASE  (Neon — serverless Postgres)
# Setup:
#   1. Create a free project at https://neon.tech
#   2. Copy the "Connection string" from the Neon dashboard (use the
#      "Pooled connection" / "Connection pooling" URL for serverless).
#   3. Run the schema once:  psql $DATABASE_URL -f schema.sql
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require


# -----------------------------------------------------------------------------
# GOOGLE OAUTH 2.0  (for Gmail API access)
# Setup:
#   1. Go to https://console.cloud.google.com/ → Create or select a project.
#   2. APIs & Services → Library → enable "Gmail API".
#   3. APIs & Services → Credentials → Create Credentials → OAuth client ID.
#      • Application type: Web application
#      • Authorized redirect URIs: add http://localhost:3456
#   4. Download the client ID and secret.
#   5. Run:  node scripts/get-oauth-token.mjs
#      Sign in as grm.secret.network@gmail.com and approve Gmail access.
#      Paste the printed refresh token below.
# -----------------------------------------------------------------------------

GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//0g...

# The Gmail address that forwards emails into Cue.
# The ingest endpoint omits this address from extracted contacts.
GMAIL_USER_EMAIL=grm.secret.network@gmail.com

# Your full name — used to filter YOU out of extracted contacts.
# Claude sometimes picks up the inbox owner under a different email address;
# this ensures you never appear in your own contact list.
GMAIL_USER_NAME=Georgia Messinger


# -----------------------------------------------------------------------------
# GOOGLE CLOUD PUB/SUB  (push notifications from Gmail)
# Setup:
#   1. In the same Google Cloud project, go to Pub/Sub → Topics → Create topic.
#      Name it something like: cue-email-ingest
#   2. Grant Gmail permission to publish to that topic:
#      • Topic → Permissions → Add principal
#      • Principal:  gmail-api-push@system.gserviceaccount.com
#      • Role:       Pub/Sub Publisher
#   3. Create a Push subscription on that topic:
#      • Subscription ID: cue-email-ingest-push
#      • Delivery type: Push
#      • Endpoint URL:
#          https://<your-app>.vercel.app/api/email/ingest?token=<PUBSUB_WEBHOOK_SECRET>
#      • (Generate PUBSUB_WEBHOOK_SECRET with: openssl rand -hex 32)
#   4. Deploy your app to Vercel first so the endpoint exists before you
#      activate the subscription.
#   5. Register the watch by calling once:
#        curl -X POST https://<your-app>.vercel.app/api/email/setup \
#             -H "Authorization: Bearer <SETUP_SECRET>"
#
# Gmail watch() expires after ~7 days — renew it weekly by calling
# /api/email/setup again, or set a Vercel cron job to do it automatically.
# -----------------------------------------------------------------------------

GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC_NAME=cue-email-ingest

# A secret random token appended to the ingest webhook URL.
# Generate with:  openssl rand -hex 32
PUBSUB_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32


# -----------------------------------------------------------------------------
# SETUP ENDPOINT SECRET
# Protects POST /api/email/setup from being called by anyone but you.
# Generate with:  openssl rand -hex 32
# Use as:  Authorization: Bearer <value>
# -----------------------------------------------------------------------------

SETUP_SECRET=generate-with-openssl-rand-hex-32
